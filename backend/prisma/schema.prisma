// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  password String
  name     String?
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  imageUrl    String?
  link        String?
  github      String?
  tags        String[]
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Experience {
  id          Int      @id @default(autoincrement())
  company     String
  position    String
  startDate   DateTime
  endDate     DateTime?
  current     Boolean  @default(false)
  description String
  order       Int      @default(0)
}

model Skill {
  id       Int    @id @default(autoincrement())
  name     String
  category String // e.g., "Frontend", "Backend", "Tools"
  icon     String?
  level    Int    @default(5) // 1-5
}

model Profile {
  id        Int     @id @default(autoincrement())
  name      String
  title     String
  bio       String
  avatarUrl String?
  email     String?
  socials   Json?   // { github: string, linkedin: string, etc }
}
