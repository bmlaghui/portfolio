# Production Environment Variables - COPY TO .env.prod AND FILL VALUES
# WARNING: Never commit .env.prod to git.

# Public web port exposed by the frontend
FRONTEND_PORT=8081

# PostgreSQL credentials (utilisés par le conteneur db)
DB_USER=portfolio_prod
DB_PASSWORD=change_me_hex_password_no_special_chars
DB_NAME=portfolio

# DATABASE_URL complète (copier DB_USER et DB_PASSWORD ici, URL-encodé automatiquement si hex)
DATABASE_URL=postgresql://portfolio_prod:change_me_hex_password_no_special_chars@db:5432/portfolio?schema=public

# Backend auth (générer avec: openssl rand -hex 48)
JWT_SECRET=change_me_long_hex_jwt_secret
JWT_REFRESH_SECRET=change_me_long_hex_refresh_secret
MFA_ENCRYPTION_KEY=change_me_independent_long_hex_mfa_key
ANALYTICS_SALT=change_me_independent_analytics_hash_salt
