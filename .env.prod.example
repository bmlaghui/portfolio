# Production Environment Variables - COPY TO .env.prod AND FILL VALUES
# WARNING: Never commit .env.prod to git.

# Public web port exposed by the frontend
FRONTEND_PORT=8081

# PostgreSQL credentials
DB_USER=change_me_db_user
DB_PASSWORD=change_me_strong_password
DB_NAME=portfolio

# Backend auth
JWT_SECRET=change_me_long_random_jwt_secret
JWT_REFRESH_SECRET=change_me_long_random_refresh_secret
